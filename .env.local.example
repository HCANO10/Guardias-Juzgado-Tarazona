# Configuración de variables de entorno para el Juzgado de Tarazona
# Copia este archivo como .env.local y rellena los valores.

# Supabase (Obligatorio)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Groq AI (Obligatorio para el generador de guardias)
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# Configuración de la App
NEXT_PUBLIC_APP_URL=http://localhost:3000
ACME_ADMIN_EMAIL=admin@juzgado.es
